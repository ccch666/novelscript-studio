{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://novelscript.studio/schema/screenplay.schema.json",
  "title": "NovelScript Screenplay YAML Schema",
  "description": "A structured YAML screenplay draft converted from three or more novel chapters.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metadata",
    "source",
    "characters",
    "locations",
    "scenes",
    "adaptation_report"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "version",
        "format",
        "generated_at",
        "style"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "format": {
          "type": "string",
          "const": "screenplay_yaml"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time"
        },
        "style": {
          "type": "string",
          "enum": [
            "film",
            "short_drama",
            "stage",
            "web_series",
            "custom"
          ]
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "chapter_count",
        "language",
        "chapters"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "chapter_count": {
          "type": "integer",
          "minimum": 3
        },
        "language": {
          "type": "string",
          "minLength": 2
        },
        "chapters": {
          "type": "array",
          "minItems": 3,
          "items": {
            "$ref": "#/$defs/chapter"
          }
        }
      }
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/character"
      }
    },
    "locations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/location"
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scene"
      }
    },
    "adaptation_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scene_count",
        "character_count",
        "dialogue_count",
        "action_count",
        "validation_status",
        "repair_rounds"
      ],
      "properties": {
        "scene_count": {
          "type": "integer",
          "minimum": 1
        },
        "character_count": {
          "type": "integer",
          "minimum": 1
        },
        "dialogue_count": {
          "type": "integer",
          "minimum": 0
        },
        "action_count": {
          "type": "integer",
          "minimum": 0
        },
        "validation_status": {
          "type": "string",
          "enum": [
            "passed",
            "failed",
            "repaired"
          ]
        },
        "repair_rounds": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        },
        "compression_notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  },
  "$defs": {
    "chapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "word_count",
        "summary"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^chapter_[0-9]{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "word_count": {
          "type": "integer",
          "minimum": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "key_events": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "character": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "role",
        "description",
        "motivation"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^char_[0-9]{3}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "aliases": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "role": {
          "type": "string",
          "enum": [
            "protagonist",
            "antagonist",
            "supporting",
            "minor",
            "narrator",
            "unknown"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "motivation": {
          "type": "string",
          "minLength": 1
        },
        "relationships": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "target",
              "relation"
            ],
            "properties": {
              "target": {
                "type": "string",
                "pattern": "^char_[0-9]{3}$"
              },
              "relation": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "location": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^loc_[0-9]{3}$"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "visual_notes": {
          "type": "string"
        }
      }
    },
    "scene": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "chapter_refs",
        "source_excerpt",
        "location_id",
        "time_of_day",
        "characters",
        "summary",
        "conflict",
        "beats",
        "adaptation_notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^scene_[0-9]{3}$"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "chapter_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^chapter_[0-9]{3}$"
          }
        },
        "source_excerpt": {
          "type": "string",
          "minLength": 1
        },
        "location_id": {
          "type": "string",
          "pattern": "^loc_[0-9]{3}$"
        },
        "time_of_day": {
          "type": "string",
          "enum": [
            "dawn",
            "morning",
            "day",
            "afternoon",
            "evening",
            "night",
            "unknown"
          ]
        },
        "characters": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^char_[0-9]{3}$"
          }
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "conflict": {
          "type": "string",
          "minLength": 1
        },
        "beats": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/beat"
          }
        },
        "adaptation_notes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "compression",
            "rationale"
          ],
          "properties": {
            "compression": {
              "type": "string",
              "minLength": 1
            },
            "rationale": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "beat": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "content"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "action",
            "dialogue",
            "narration",
            "stage_direction",
            "transition"
          ]
        },
        "speaker": {
          "type": "string",
          "pattern": "^char_[0-9]{3}$"
        },
        "content": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "dialogue"
              }
            },
            "required": [
              "type"
            ]
          },
          "then": {
            "required": [
              "speaker"
            ]
          }
        }
      ]
    }
  }
}

